{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "${file}",
        "-o",
        "${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": []
    },
    {
      "label": "run executable",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "\"${fileBasenameNoExtension}.exe\" < input.txt > output.txt"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": []
    },
    {
      "label": "compile and run",
      "dependsOrder": "sequence",
      "dependsOn": ["compile", "run executable"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}